# Dependencies
node_modules/
.pnpm-store/

# Per-package build outputs are regenerated by the build; only the root
# /dist/ (the bundled GitHub Action) is committed.
packages/*/dist/
apps/*/dist/
**/build/
**/.turbo/
**/.next/
**/.astro/
**/coverage/
**/*.tsbuildinfo

# Generated artifacts (CI re-creates these)
profile.json
cv.pdf
assets/cards/*.svg

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Environment
.env
.env.local
.env.*.local

# Test
.nyc_output/
.vitest-cache/

# Local editor / tooling state
.claude/
.cursor/
.history/

