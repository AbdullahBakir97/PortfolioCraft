{
  "name": "@portfoliocraft/action",
  "version": "0.2.0",
  "description": "PortfolioCraft GitHub Action entrypoint.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "bundle": "pnpm build && ncc build dist/index.js -o ../../dist --minify --license licenses.txt --target es2022 && node ./scripts/copy-templates.mjs"
  },
  "dependencies": {
    "@actions/cache": "6.0.0",
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "@portfoliocraft/core": "workspace:*",
    "@portfoliocraft/renderers": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@vercel/ncc": "0.38.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
