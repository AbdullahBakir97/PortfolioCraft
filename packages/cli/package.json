{
  "name": "portfoliocraft",
  "version": "0.4.0",
  "description": "Generate a living portfolio (README sections, JSON Resume, PDF CV, SVG cards) from your GitHub activity.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "portfoliocraft": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@portfoliocraft/core": "workspace:*",
    "@portfoliocraft/renderers": "workspace:*",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
