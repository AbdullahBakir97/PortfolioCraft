{
  "name": "@devportfolio/core",
  "version": "0.1.0",
  "description": "Framework-free engine for DevPortfolio: GitHub ingestion, scoring, classification.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@octokit/graphql": "8.1.2",
    "@octokit/plugin-retry": "7.1.4",
    "@octokit/plugin-throttling": "9.4.0",
    "@octokit/rest": "21.0.2",
    "pino": "9.5.0",
    "yaml": "2.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@vitest/coverage-v8": "2.1.8",
    "msw": "2.14.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
