{
  "name": "@portfoliocraft/core",
  "version": "0.2.0",
  "description": "Framework-free engine for PortfolioCraft: GitHub ingestion, scoring, classification.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@octokit/graphql": "9.0.3",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@octokit/rest": "22.0.1",
    "pino": "10.3.1",
    "yaml": "2.8.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "@vitest/coverage-v8": "4.1.5",
    "msw": "2.14.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
